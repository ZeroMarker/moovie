<article class="movie-detail">
  <%= link_to "Back to movies", movies_path, class: "back-link" %>

  <div class="movie-detail__header">
    <div>
      <p class="eyebrow"><%= @movie.release_year %><%= " / #{@movie.rating}" if @movie.rating.present? %></p>
      <h1><%= @movie.title %></h1>
      <p class="lede"><%= @movie.synopsis %></p>
    </div>
    <% if @movie.poster_url.present? %>
      <%= image_tag @movie.poster_url, alt: @movie.title, class: "poster" %>
    <% end %>
  </div>

  <section class="section">
    <h2>Reviews</h2>
    <% if @movie.reviews.any? %>
      <div class="review-list">
        <% @movie.reviews.each do |review| %>
          <article class="review">
            <strong><%= review.reviewer_name %></strong>
            <span><%= review.rating %>/5</span>
            <p><%= review.body %></p>
          </article>
        <% end %>
      </div>
    <% else %>
      <p>No reviews yet.</p>
    <% end %>
  </section>
</article>
